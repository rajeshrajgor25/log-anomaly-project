# Backend Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy code
COPY backend/ .

# Expose port
EXPOSE 8000

# ✅ Run using uvicorn (IMPORTANT)
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]